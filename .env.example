# NETICS Voice — environment configuration
# Copy to .env.local. The prototype runs fully mocked with NO secrets required.

# ── Provider selection (default: mock) ─────────────────────────────
NEXT_PUBLIC_AI_PROVIDER=mock            # mock | openai | anthropic
NEXT_PUBLIC_TELEPHONY_PROVIDER=mock     # mock | twilio | vonage
NEXT_PUBLIC_PAYMENT_PROVIDER=mock       # mock | stripe | paystack | flutterwave

# ── AI (only when NEXT_PUBLIC_AI_PROVIDER != mock) ─────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPGRAM_API_KEY=            # speech-to-text
# ELEVENLABS_API_KEY=          # text-to-speech
# VECTOR_DB_URL=               # RAG embeddings (pgvector / Pinecone)

# ── Telephony ──────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ── Messaging ──────────────────────────────────────────────────────
# META_WHATSAPP_TOKEN=

# ── Payments ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# PAYSTACK_SECRET_KEY=

# ── Backend (planned) ──────────────────────────────────────────────
# DATABASE_URL=postgres://...
# REDIS_URL=redis://...
# S3_ENDPOINT=
# S3_BUCKET=
# JWT_SECRET=
